# Cordn server signing key (Optional, if not provided, a fresh key will be generated)
CORDN_SERVER_PRIVATE_KEY=

# Relay URLs for transport connections, comma-separated
CORDN_RELAY_URLS=wss://relay.contextvm.org

# Optional server metadata
CORDN_SERVER_NAME=cordn-server
CORDN_SERVER_ABOUT=
CORDN_SERVER_WEBSITE=

# Publish server announcements on Nostr
CORDN_ANNOUNCED=false

# Storage backend: memory or sqlite
CORDN_STORAGE_BACKEND=memory

# SQLite database path when CORDN_STORAGE_BACKEND=sqlite
CORDN_SQLITE_PATH=./cordn.sqlite
