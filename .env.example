# ContextVM server signing key (Optional, if not provided, a fresh key will be generated)
CVM_MLS_SERVER_PRIVATE_KEY=

# Relay URLs for transport connections, comma-separated
CVM_MLS_RELAY_URLS=wss://relay.contextvm.org

# Optional server metadata
CVM_MLS_SERVER_NAME=cordn-server
CVM_MLS_SERVER_ABOUT=
CVM_MLS_SERVER_WEBSITE=

# Publish server announcements on Nostr
CVM_MLS_ANNOUNCED=false

# Storage backend: memory or sqlite
CVM_MLS_STORAGE_BACKEND=memory

# SQLite database path when CVM_MLS_STORAGE_BACKEND=sqlite
CVM_MLS_SQLITE_PATH=./cordn.sqlite
