{
  "name": "cvm-mls",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm run server:start",
    "build": "pnpm build ./src/index.ts --outdir ./dist --target pnpm",
    "client:cli": "node --experimental-strip-types ./src/client/cli/main.ts",
    "server:start": "node --experimental-strip-types ./src/server/main.ts",
    "test": "vitest run ./src",
    "format": "prettier --write ./src"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "vitest": "^4.0.17"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@contextvm/sdk": "^0.9.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "nostr-tools": "^2.23.3",
    "ts-mls": "^2.0.0-rc.10",
    "zod": "^4.3.6"
  }
}
